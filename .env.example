# ── Django core ───────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=sos_frontend_db
DB_USER=sos_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ── Shopify Storefront API ────────────────────────────────────────────────────
# IMPORTANT: These values are SERVER-SIDE ONLY.
# Never expose SHOPIFY_STOREFRONT_ACCESS_TOKEN in templates, JS, or API responses.
# The Storefront Access Token is a PUBLIC token with read-only storefront scope.
# Never use Admin API tokens here — those belong in a separate, private service.
SHOPIFY_STORE_DOMAIN=your-store-name.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_api_token_here
SHOPIFY_API_VERSION=2026-04

# ── Email (choose one) ────────────────────────────────────────────────────────
# Option A: SendGrid (recommended for production)
SENDGRID_API_KEY=

# Option B: SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@singleoriginsociety.com
